{
  "name": "vscode-isomorphic-git",
  "displayName": "vscode-isomorphic-git",
  "description": "Add the isomorphic-git support to vscode-pwa",
  "version": "0.0.3",
  "publisher": "0xgg",
  "engines": {
    "vscode": "^1.120.0"
  },
  "extensionKind": [
    "ui",
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "categories": [
    "SCM Providers"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:.git",
    "onCommand:isomorphic-git.init",
    "onCommand:isomorphic-git.clone"
  ],
  "main": "./dist/extension.js",
  "browser": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "isomorphic-git.init",
        "title": "Initialize Repository",
        "category": "isomorphic-git",
        "icon": "$(add)"
      },
      {
        "command": "isomorphic-git.commit",
        "title": "Commit",
        "category": "isomorphic-git",
        "icon": "$(check)"
      },
      {
        "command": "isomorphic-git.refresh",
        "title": "Refresh Git Status",
        "category": "isomorphic-git",
        "icon": "$(refresh)"
      },
      {
        "command": "isomorphic-git.stage",
        "title": "Stage Changes",
        "category": "isomorphic-git",
        "icon": "$(plus)"
      },
      {
        "command": "isomorphic-git.stageAll",
        "title": "Stage All Changes",
        "category": "isomorphic-git",
        "icon": "$(add)"
      },
      {
        "command": "isomorphic-git.unstage",
        "title": "Unstage Changes",
        "category": "isomorphic-git",
        "icon": "$(remove)"
      },
      {
        "command": "isomorphic-git.unstageAll",
        "title": "Unstage All Changes",
        "category": "isomorphic-git",
        "icon": "$(remove)"
      },
      {
        "command": "isomorphic-git.clean",
        "title": "Discard Changes",
        "category": "isomorphic-git",
        "icon": "$(discard)"
      },
      {
        "command": "isomorphic-git.cleanAll",
        "title": "Discard All Changes",
        "category": "isomorphic-git",
        "icon": "$(discard)"
      },
      {
        "command": "isomorphic-git.openGitConfig",
        "title": "Open Git Config",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.addRemote",
        "title": "Add Remote",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.removeRemote",
        "title": "Remove Remote",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.checkout",
        "title": "Checkout",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.deleteBranch",
        "title": "Delete Branch",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.githubSignIn",
        "title": "GitHub: Sign In",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.githubSignOut",
        "title": "GitHub: Sign Out",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.clone",
        "title": "Clone",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.pullFrom",
        "title": "Pull from",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.pushTo",
        "title": "Push to",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.fetch",
        "title": "Fetch",
        "category": "isomorphic-git"
      },
      {
        "command": "isomorphic-git.merge",
        "title": "Merge Branch",
        "category": "isomorphic-git"
      }
    ],
    "menus": {
      "scm/title": [
        {
          "command": "isomorphic-git.commit",
          "group": "navigation",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.refresh",
          "group": "navigation",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.fetch",
          "group": "1_header@1",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.pullFrom",
          "group": "1_header@2",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.pushTo",
          "group": "1_header@3",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.clone",
          "group": "1_header@4",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.checkout",
          "group": "1_header@5",
          "when": "scmProvider == isomorphic-git"
        },
        {
          "command": "isomorphic-git.merge",
          "group": "1_header@6",
          "when": "scmProvider == isomorphic-git"
        }
      ],
      "scm/resourceGroup/context": [
        {
          "command": "isomorphic-git.cleanAll",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == workingTree",
          "group": "inline"
        },
        {
          "command": "isomorphic-git.stageAll",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == workingTree",
          "group": "inline"
        },
        {
          "command": "isomorphic-git.unstageAll",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == index",
          "group": "inline"
        }
      ],
      "scm/resourceState/context": [
        {
          "command": "isomorphic-git.clean",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == workingTree",
          "group": "inline"
        },
        {
          "command": "isomorphic-git.stage",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == workingTree",
          "group": "inline"
        },
        {
          "command": "isomorphic-git.unstage",
          "when": "scmProvider == isomorphic-git && scmResourceGroup == index",
          "group": "inline"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "scm",
        "contents": "The folder currently open doesn't have a git repository. You can initialize a repository which will enable source control features powered by [isomorphic-git](https://github.com/isomorphic-git/isomorphic-git/).  \n[Initialize Repository](command:isomorphic-git.init)  \n[Clone a Repository](command:isomorphic-git.clone)"
      }
    ],
    "configuration": {
      "title": "isomorphic-git",
      "properties": {
        "isomorphic-git.authorName": {
          "description": "Git author name",
          "default": "Anonymous",
          "type": "string"
        },
        "isomorphic-git.authorEmail": {
          "description": "Git author email",
          "default": "anonymous@git.com",
          "type": "string"
        },
        "isomorphic-git.libcurlWispUrl": {
          "description": "Wisp websocket endpoint used by libcurl.js for GitHub OAuth and Git HTTP traffic.",
          "default": "https://us-west.wisp.q13x.com/",
          "type": "string"
        },
        "isomorphic-git.githubOAuthClientId": {
          "description": "GitHub OAuth App client ID used for Device Flow login. The OAuth App must have Device Flow enabled.",
          "default": "",
          "type": "string"
        },
        "isomorphic-git.credentials": {
          "type": "array",
          "items": {
            "type": "object",
            "title": "inner objects",
            "properties": {
              "url": {
                "type": "string",
                "description": "The URL of the remote Git repository. Eg 'https://github.com/0xgg/vscode-isomorphic-git.git'",
                "default": ""
              },
              "username": {
                "type": "string",
                "description": "The username",
                "default": ""
              },
              "password": {
                "type": "string",
                "description": "The password",
                "default": ""
              }
            }
          },
          "default": [],
          "description": "Git credentials"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "test-compile": "tsc -p ./",
    "test-watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "test": "npm run test-compile && npm run lint",
    "test-clone": "vscode-test-web --browser chromium --headless=true --host localhost --port 3001 --extensionDevelopmentPath=. --extensionTestsPath=test-web/clone-smoke.js .",
    "test-web": "vscode-test-web --browser chromium --host 127.0.0.1 --port 3000 --extensionDevelopmentPath=. ."
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/vscode": "^1.120.0",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "@vscode/test-web": "^0.0.80",
    "buffer": "^6.0.3",
    "eslint": "^10.5.0",
    "path-browserify": "^1.0.1",
    "ts-loader": "^9.6.0",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "isomorphic-git": "^1.38.4",
    "libcurl.js": "^0.7.4"
  }
}
